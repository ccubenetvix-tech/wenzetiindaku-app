# ─── App Environment ───────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_ENV=development

# ─── API ───────────────────────────────────────────────────────────────────────
# Must include /api suffix — e.g. https://wenzetiindaku-backend.onrender.com/api
EXPO_PUBLIC_API_BASE_URL=https://wenzetiindaku-backend.onrender.com/api
EXPO_PUBLIC_API_TIMEOUT=10000

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# Set to false when backend is ready; true to use local mock data
EXPO_PUBLIC_ENABLE_MOCK_DATA=false
EXPO_PUBLIC_ENABLE_DEBUG_LOGS=true

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ─── EAS Build ─────────────────────────────────────────────────────────────────
# Found in expo.dev → your project → settings
# Goes in app.json extra.eas.projectId, NOT in .env
# EXPO_PUBLIC_EAS_PROJECT_ID=

# ─── Crashlytics ───────────────────────────────────────────────────────────────
# Firebase Crashlytics is configured via google-services.json / GoogleService-Info.plist
# No env var needed here
