{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development",
        "EXPO_PUBLIC_ENABLE_MOCK_DATA": "true",
        "EXPO_PUBLIC_ENABLE_DEBUG_LOGS": "true",
        "EXPO_PUBLIC_API_BASE_URL": "https://api-dev.wenzetiindaku.com/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "staging",
        "EXPO_PUBLIC_ENABLE_MOCK_DATA": "false",
        "EXPO_PUBLIC_ENABLE_DEBUG_LOGS": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://api-staging.wenzetiindaku.com/v1"
      },
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "EXPO_PUBLIC_ENABLE_MOCK_DATA": "false",
        "EXPO_PUBLIC_ENABLE_DEBUG_LOGS": "false",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.wenzetiindaku.com/v1"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID@example.com",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
