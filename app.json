{
  "expo": {
    "name": "Wenze Tii Ndaku",
    "slug": "wenzetiindaku-app",
    "owner": "ccubenetvix-tech",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wenzetiindakuapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ccubenetvixtech.wenzetiindakuapp",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Wenze Tii Ndaku to access your camera to upload product images.",
        "NSPhotoLibraryUsageDescription": "Allow Wenze Tii Ndaku to access your photos to upload a profile picture.",
        "NSLocationWhenInUseUsageDescription": "Allow Wenze Tii Ndaku to use your location to show nearby stores and autofill your delivery address.",
        "NSUserNotificationsUsageDescription": "We'll send you order updates and delivery notifications."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F2A4A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.ccubenetvixtech.wenzetiindakuapp",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#0F2A4A",
          "defaultChannel": "orders"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F2A4A",
          "dark": {
            "backgroundColor": "#0A1F38"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "957b6031-701a-40fb-bc55-c0f473d851e2"
      }
    }
  }
}
